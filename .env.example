# Maison Concierge — environment configuration
# Copy to .env and fill in. Never commit the real .env.

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# --- Storage ---
CHROMA_DIR=.chroma
REDIS_URL=redis://localhost:6379/0

# --- App ---
APP_LOCALE_DEFAULT=en           # en | fr
APP_LOG_LEVEL=INFO
APP_ESCALATION_THRESHOLD=0.65   # confidence below this routes to human SA

# --- Visual search (optional, gated by CLIP_ENABLED) ---
CLIP_ENABLED=false
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# --- Observability ---
METRICS_DIR=data/metrics
